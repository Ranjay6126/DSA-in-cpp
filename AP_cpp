#include<iostream>
using namespace std;

void Arithmetic_Progression(int a, int d, int n){
    int AP = a + (n - 1) * d;
    cout << "The " << n << "-th term of the AP is: " << AP << endl;
}

int main(){
    int a, d, n;
    cout << "Enter the first term (a), common difference (d), and term number (n): ";
    cin >> a >> d >> n;

    Arithmetic_Progression(a, d, n);

    return 0;
}
